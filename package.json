{
  "name": "sampark-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "prisma": {
    "seed": "tsx src/db/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node --input-type=module -e \"import{cpSync}from'node:fs';cpSync('src/assets','dist/assets',{recursive:true})\"",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6",
    "otplib": "^12.0.1",
    "pdfmake": "^0.3.11",
    "pg-boss": "^10.1.5",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pdfmake": "^0.3.3",
    "dotenv": "^16.4.7",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
