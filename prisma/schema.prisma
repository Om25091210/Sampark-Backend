// SAMPARK backend — Prisma schema (Phase 1).
// Field names are camelCase (matching the camelCase wire entity contract) and mapped
// to snake_case columns. Enum values are lowercase to serialize verbatim on the wire
// (per ADR / CLAUDE.md rule 10). All primary domain tables carry a soft-delete column.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (lowercase wire values; CadreFilter keeps client acronyms) ──────────

enum Role {
  super_admin
  admin
  officer
  viewer
}

enum CadreCategory {
  surrendered
  jail
  thana
}

enum CadreFilter {
  DVCM
  ACM
  PM
}

enum AlertLevel {
  critical
  warning
  normal
}

// ADR-019. Classifies WHERE a cadre surrendered relative to Bijapur, which the
// dashboard splits into two tiles. Deliberately a separate column from
// `surrenderLocation`: that field is free text recording the place ("थाना
// नारायणपुर"), not a classification, and it is null for cadres who never
// surrendered. Null here means "not applicable / not yet classified" — only
// `category = surrendered` rows carry a value.
enum SurrenderOrigin {
  district // Bijapur district
  other    // another district or state
}

// ADR-026. Lifecycle of an officer/admin-proposed edit to a cadre record.
// `applied` is terminal and means the change is live on the cadre; `approved`
// is never a resting state (approval and application happen in one transaction),
// so it is deliberately absent — a request that says "approved" but whose value
// is not on the cadre would be the exact class of lie this project keeps undoing.
enum ChangeRequestStatus {
  pending
  applied
  rejected
  cancelled  // withdrawn by the submitter before it was decided
  stale      // the underlying value moved after submission; never applied
}

enum ReportingPlace {
  thana
  village
}

enum PersonStatus {
  alive
  dead
}

// ADR-038. The register's लिंग column, exactly two clean values. Lowercase to
// serialize verbatim on the wire (CLAUDE.md rule 10), like every other enum here.
// Caste is deliberately NOT an enum: it is free text with dozens of open-ended
// values, and freezing it into an enum would reject the next spelling the register
// records.
enum Gender {
  male
  female
}

// ─── Users (officers + admins) ─────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  // ADR-042. The INSTITUTIONAL ID — e.g. "SDOPKUTRU01", "SHOGNGL07" — NOT a person's
  // name. Real names are deliberately not stored anywhere (client decision). Unique
  // because it is the account's identity AND the upsert key for POST /users/import.
  //
  // Consequence, recorded here because it is easy to forget at a call site: every
  // audit row, change request and report attributes to this ID, so accountability is
  // only as granular as the ID. An ID held by several people resolves to the ID, never
  // to the person. See ADR-042 Consequences.
  name          String    @unique
  // ADR-042. Nullable: the SMS-OTP track is gone and these institutional accounts have
  // no phone. Kept (unique, nullable) rather than dropped so historical rows and any
  // future contact use keep a home — Postgres allows many NULLs under a unique index.
  phone         String?   @unique
  // ADR-042. The login credential. `<id-lowercased>@sampark.internal` — a non-routable
  // ICANN-reserved private TLD; these inboxes do not exist, which is WHY password
  // reset is super_admin-driven (Phase B) and never self-service by email.
  email         String?   @unique
  // ADR-042. scrypt (node:crypto) — see lib/password.ts. NULL means "no password set
  // yet": an imported account cannot log in until a super_admin sets one (Phase B).
  passwordHash  String?   @map("password_hash")
  // ADR-042/SDR-001. TOTP applies to admin + super_admin ONLY (14 accounts), never the
  // 60 field IDs. `totpConfirmedAt` distinguishes "secret generated, enrolment never
  // completed" from "enrolled" — without it a half-finished enrolment locks the
  // account out, because login would stop re-offering the provisioning URI.
  totpSecret    String?   @map("totp_secret")
  totpConfirmedAt DateTime? @map("totp_confirmed_at")
  role          Role      @default(officer)
  designation   String?
  // ADR-042. Scope fields for the org hierarchy → Role mapping:
  //   HQ         = super_admin, thana + subDivision BOTH null  -> unrestricted
  //   SDOP       = admin,       subDivision set                -> that sub-division
  //   Thana/SHO  = officer,     thana set                      -> that thana
  // These are compared against Cadre.thana / Cadre.subDivision, so the values must
  // match those columns EXACTLY — see Phase 0 normalisation (ADR-043).
  thana         String?
  subDivision   String?   @map("sub_division")
  avatarUrl     String?   @map("avatar_url")
  badgeImageUrl String?   @map("badge_image_url")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  reports        Report[]       @relation("ReportReporter")
  assignedCadres Cadre[]        @relation("CadreAssignedOfficer")
  refreshTokens  RefreshToken[]

  lastEditedCadres       Cadre[]              @relation("CadreLastEditor") // ADR-027
  // ADR-026
  submittedChanges       CadreChangeRequest[] @relation("ChangeSubmitter")
  adminApprovedChanges   CadreChangeRequest[] @relation("ChangeAdminApprover")
  superApprovedChanges   CadreChangeRequest[] @relation("ChangeSuperAdminApprover")
  decidedChanges         CadreChangeRequest[] @relation("ChangeDecider")

  @@map("users")
}

// ─── Cadres (surrendered / jail / thana persons) ───────────────────────────────

model Cadre {
  id                 Int            @id @default(autoincrement())
  // ADR-025. The official register serial number carried over from the paper records.
  // Deliberately NOT `id`: `id` is a surrogate autoincrement PK with gaps from
  // deletes, and the ~1,790-row import will reassign every PK — a "serial number"
  // an officer has written in a register must not change under them. Nullable
  // because existing rows predate the import that supplies it; unique because a
  // register number that repeats identifies nothing (a failed import surfacing
  // duplicate serials is the point, not a problem).
  serialNumber       String?        @unique @map("serial_number")
  name               String
  phone              String
  thana              String
  currentAddress     String         @map("current_address")
  permanentAddress   String?        @map("permanent_address")
  designation        String
  category           CadreCategory
  filter             CadreFilter?
  alertLevel         AlertLevel     @map("alert_level")
  avatarUrl          String?        @map("avatar_url")
  alertDate          DateTime?      @map("alert_date")
  incident           String?
  verificationOffice String?        @map("verification_office")
  supervisoryOffice  String?        @map("supervisory_office")
  alertTag           String?        @map("alert_tag")
  aliases            String[]
  surrenderDate      DateTime?        @map("surrender_date")
  surrenderLocation  String?          @map("surrender_location")
  surrenderOrigin    SurrenderOrigin? @map("surrender_origin")
  surrenderYear      String?          @map("surrender_year")
  regiment           String?
  familyGroupInfo    String?        @map("family_group_info")
  subDivision        String?        @map("sub_division")
  // ADR-040. Home district (dropdown on the edit form: the 7 Bastar-region districts).
  // Nullable like subDivision — existing rows predate it; the Apps Script backfills it.
  district           String?        @map("district")
  // ADR-036. Date of birth, stored — age is DERIVED from it on read, never stored.
  // A stored age is wrong the day after it is written and has no way to know it;
  // a birth date is a fact that does not rot. Nullable: existing rows predate it and
  // the ~1,790-row import supplies it later. Manually enterable now (BE#6), not
  // gated on the import.
  dateOfBirth        DateTime?      @map("date_of_birth") @db.Date
  // ADR-036. Immediate family, as three plain columns (BE#7). Deliberately NOT a
  // child table or a repeatable relation list: the register records exactly these
  // three names, and a `cadre_relations` table would be schema weight for a
  // fixed-arity fact. `familyGroupInfo` above stays — it is the free-text
  // "who they live with" note, a different thing from a parent's name.
  fatherName         String?        @map("father_name")
  motherName         String?        @map("mother_name")
  spouseName         String?        @map("spouse_name")
  // ADR-038. Demographic facts carried over from the paper register by the one-time
  // historical import (Design-Docs#7). Both nullable for the same reason
  // serialNumber and dateOfBirth are: existing rows predate the import that supplies
  // them, and caste is only ~82% filled in the source. `gender` is a two-value enum
  // (पुरूष/महिला); `caste` is free text (जाति), never an enum — see the Gender enum note.
  gender             Gender?        @map("gender")
  caste              String?        @map("caste")
  // ADR-029. The four hardcopy documents, tracked INDIVIDUALLY. ADR-026 shipped
  // these as one `hardcopyDocsExist` boolean; the client asked for them separately,
  // and they were right — "the paperwork exists" is unanswerable when the Aadhaar
  // is on file and the agreement letter is not. One flag forced an officer to lie
  // in one direction or the other.
  //
  // Each goes through the approval chain like any other cadre fact: ticking one is
  // asserting a document physically exists, which is a claim someone above the
  // officer signs off on. Default false = "not confirmed present", never null — a
  // tri-state nobody asked for.
  hasAadhaar         Boolean        @default(false) @map("has_aadhaar")
  hasBankAccount     Boolean        @default(false) @map("has_bank_account")
  hasAbProforma      Boolean        @default(false) @map("has_ab_proforma")
  hasAgreementLetter Boolean        @default(false) @map("has_agreement_letter")
  // ADR-029. Durable S3 key for the cadre's photo. ADR-016's lesson: store the KEY,
  // never a presigned URL (which expires ≤7d and would rot in the column). The
  // legacy `avatarUrl` above stays for rows that predate this; the serializer
  // prefers a freshly-signed `avatarKey` and falls back to it.
  avatarKey          String?        @map("avatar_key")
  assignedOfficerId  Int?           @map("assigned_officer_id")
  // ADR-027. Who last changed this record's contents, and when. Deliberately NOT
  // `updatedAt`: that moves on every write including assignment transfers, so it
  // cannot answer "has someone edited this cadre's details recently?" — which is
  // the question an officer asks before proposing an edit of their own.
  //
  // Denormalised on purpose, unlike nextReportingDueAt (ADR-022, derived). This is
  // not a function of existing data — it is a fact recorded at write time, and only
  // the two write paths (a change request applying, a direct tag/alias write) ever
  // set it. Nothing else can make it drift.
  lastEditedAt       DateTime?      @map("last_edited_at")
  lastEditedById     Int?           @map("last_edited_by_id")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  assignedOfficer User?                @relation("CadreAssignedOfficer", fields: [assignedOfficerId], references: [id])
  lastEditedBy    User?                @relation("CadreLastEditor", fields: [lastEditedById], references: [id]) // ADR-027
  reports         Report[]
  changeRequests  CadreChangeRequest[] // ADR-026

  @@index([category])
  @@index([alertLevel])
  @@index([assignedOfficerId])
  // The two surrendered dashboard tiles both filter category + origin together.
  @@index([category, surrenderOrigin])
  @@map("cadres")
}

// ─── Reports (field reporting against a cadre) ─────────────────────────────────

model Report {
  id               Int            @id @default(autoincrement())
  cadreId          Int            @map("cadre_id")
  reportingPlace   ReportingPlace @map("reporting_place")
  specificLocation String         @map("specific_location")
  personStatus     PersonStatus   @map("person_status")
  currentPhone     String         @map("current_phone")
  currentActivity  String         @map("current_activity")
  // Legacy single-photo URL (may be an expired presigned URL on old rows). New
  // writes populate photoKeys instead; kept for backward-compatible reads.
  photoUrl         String?        @map("photo_url")
  // ADR-016: durable S3 object keys for report photos. Keys are stored (never the
  // presigned URL, which expires ≤7d); reads re-sign each key to a fresh GET URL.
  photoKeys        String[]       @default([]) @map("photo_keys")
  gpsLatitude      Float?         @map("gps_latitude")
  gpsLongitude     Float?         @map("gps_longitude")
  gpsAddress       String?        @map("gps_address")
  isHomeAddress    Boolean?       @map("is_home_address")
  reportedById     Int            @map("reported_by_id")
  reportedAt       DateTime       @default(now()) @map("reported_at")
  syncedAt         DateTime?      @map("synced_at")
  // ADR-013: client-supplied UUID; unique + retained for the report's lifetime (no expiry).
  idempotencyKey   String?        @unique @map("idempotency_key")
  deletedAt        DateTime?      @map("deleted_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  cadre      Cadre @relation(fields: [cadreId], references: [id])
  reportedBy User  @relation("ReportReporter", fields: [reportedById], references: [id])

  @@index([cadreId])
  @@index([reportedById])
  @@map("reports")
}

// ─── Cadre change requests (ADR-026) ───────────────────────────────────────────
//
// An officer/admin-proposed edit to a CADRE record, held until everyone above the
// submitter has signed off. Scope is deliberately the cadre, not the user account:
// officers do not edit their own profile through this.
//
// The approval ladder is "every role above you must approve":
//   officer      -> admin -> super_admin   (needsAdmin + needsSuperAdmin)
//   admin        -> super_admin            (needsSuperAdmin)
//   super_admin  -> applied immediately    (never reaches this table)
//   viewer       -> cannot submit
//
// The two required-flags are frozen ONTO THE ROW at submission time rather than
// re-derived from the submitter's current role on each read: if an officer is
// promoted to admin while their change sits pending, the change must still need
// the approvals it needed when it was made. Re-deriving would silently shorten
// the chain retroactively.
model CadreChangeRequest {
  id      Int @id @default(autoincrement())
  cadreId Int @map("cadre_id")

  // One request = one logical submission = a SET of field changes, applied or
  // rejected as a unit. Shape: { "<cadreField>": { "old": <json>, "new": <json> } }.
  // Not one row per field: a profile edit touches several at once, and per-field
  // rows let an approver half-approve an edit into a state the submitter never
  // proposed. `old` is the value read at submission time and is re-checked before
  // apply — an approval two days later must not clobber someone else's newer edit.
  changes Json

  submittedById Int      @map("submitted_by_id")
  submittedAt   DateTime @default(now()) @map("submitted_at")
  // Free-text reason from the field ("नंबर बदल गया है"). Optional.
  note          String?

  status ChangeRequestStatus @default(pending)

  needsAdmin      Boolean @default(true) @map("needs_admin")
  needsSuperAdmin Boolean @default(true) @map("needs_super_admin")

  adminApprovedById      Int?      @map("admin_approved_by_id")
  adminApprovedAt        DateTime? @map("admin_approved_at")
  superAdminApprovedById Int?      @map("super_admin_approved_by_id")
  superAdminApprovedAt   DateTime? @map("super_admin_approved_at")

  // Terminal outcomes. `decidedReason` carries a rejection reason — an officer who
  // is told only "rejected" learns nothing and will just resubmit.
  decidedAt     DateTime? @map("decided_at")
  decidedById   Int?      @map("decided_by_id")
  decidedReason String?   @map("decided_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cadre                Cadre @relation(fields: [cadreId], references: [id])
  submittedBy          User  @relation("ChangeSubmitter", fields: [submittedById], references: [id])
  adminApprovedBy      User? @relation("ChangeAdminApprover", fields: [adminApprovedById], references: [id])
  superAdminApprovedBy User? @relation("ChangeSuperAdminApprover", fields: [superAdminApprovedById], references: [id])
  decidedBy            User? @relation("ChangeDecider", fields: [decidedById], references: [id])

  // The approver queue reads pending-first, newest-first.
  @@index([status, submittedAt])
  @@index([cadreId])
  @@index([submittedById])
  @@map("cadre_change_requests")
}

// ─── Auth support ──────────────────────────────────────────────────────────────

// ADR-042. `OtpChallenge` is GONE. SMS-OTP was the officer login track (ADR-012); it
// is removed entirely in favour of email+password, so the challenge table has no
// remaining reader or writer and the migration drops it. Nothing referenced it by FK.

// SDR-002. Account-level brute-force lockout.
//
// Keyed on the SUBMITTED EMAIL STRING, deliberately NOT on a user row. If only real
// accounts could lock, a 423 would itself answer "does this account exist?" — and with
// IDs guessable by construction (SHOGNGL01…10) that is a free enumeration oracle. An
// unknown email locks exactly the same way, so 423 reveals nothing while still telling a
// genuinely locked-out officer the truth instead of leaving them retyping a correct
// password against a generic 401.
model LoginAttempt {
  email        String    @id
  failedCount  Int       @default(0) @map("failed_count")
  lastFailedAt DateTime  @default(now()) @map("last_failed_at")
  // Null = not locked. Set when failedCount crosses the threshold.
  lockedUntil  DateTime? @map("locked_until")

  @@map("login_attempts")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Audit trail (append-only, hash-chained) ───────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?     @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  prevHash   String   @map("prev_hash")
  hash       String   @unique
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─── Transactional outbox ──────────────────────────────────────────────────────

model OutboxEvent {
  id            Int       @id @default(autoincrement())
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  eventType     String    @map("event_type")
  payload       Json
  createdAt     DateTime  @default(now()) @map("created_at")
  publishedAt   DateTime? @map("published_at")

  @@index([publishedAt])
  @@map("outbox_events")
}
