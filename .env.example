# Copy to .env for local development: cp .env.example .env
# Parsed + validated at boot via src/config/env.ts.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# PostgreSQL 16. Matches docker-compose.yml credentials.
# Not needed for `prisma generate` (tests load this file via dotenv).
DATABASE_URL="postgresql://sampark:sampark@localhost:5432/sampark?schema=public"

# Auth — REQUIRED. Use a long random string in real environments.
JWT_SECRET="dev-only-change-me-to-a-long-random-string-min-32-chars"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# SMS delivery: mock logs the OTP (dev only); msg91 is not implemented yet.
SMS_PROVIDER=mock

# Staging-only escape hatch. The mock provider prints the OTP under
# NODE_ENV=development anyway, so this is unnecessary locally. It exists for a
# *deployed* staging environment, which must run NODE_ENV=production and would
# otherwise hide the code. Never true where real officers exist.
MOCK_OTP_ECHO=false

# Media storage (report photos + PDF exports).
#   mock — in-process, returns fake URLs (dev/test; no AWS needed)
#   s3   — AWS S3 in ap-south-1 (data residency); requires S3_BUCKET + AWS credentials
#          from the SDK default chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / role).
STORAGE_PROVIDER=mock
# S3_BUCKET=sampark-media
S3_REGION=ap-south-1
# Presigned-GET lifetime for returned media URLs (seconds). Max/default 7 days.
MEDIA_URL_TTL_SECONDS=604800
# Max uploaded photo size in bytes (default 10 MB).
UPLOAD_MAX_BYTES=10485760
